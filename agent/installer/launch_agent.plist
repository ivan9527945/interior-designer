<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.company.renderstudio.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/RenderStudio Agent.app/Contents/MacOS/renderstudio-agent</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/renderstudio-agent.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/renderstudio-agent.err.log</string>
</dict>
</plist>
